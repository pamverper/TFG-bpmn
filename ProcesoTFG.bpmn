    <bpmn:textAnnotation id="TextAnnotation_1t1hlb8">
      <bpmn:text>Debe estar 15 min antes</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1pcs9jr">
      <bpmn:text>tutor no puede ser tribunal de su alumno</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0m3oj9s">
      <bpmn:text>Aulas ya definidas desde principio, dos seminarios, aulas seguidas si es mismo tribunal</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1345lj4">
      <bpmn:text>Plazo maximo 10 dias antes</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0rjg1c8">
      <bpmn:text>Coordinador dijo 4 dias, documentación dice 48h</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1s4kiis">
      <bpmn:text>La adjudicación se puede realizar aunque este en departamento incorrecto</bpmn:text>
    </bpmn:textAnnotation>
